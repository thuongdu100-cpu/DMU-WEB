{
  "name": "dmu-web",
  "version": "1.0.0",
  "private": true,
  "description": "DMU NEWS — React (Vite) + Express + PostgreSQL (Prisma)",
  "scripts": {
    "start": "node backend/server.js",
    "server": "node backend/server.js",
    "server:dev": "npm run build:backend-ts && node --watch backend/server.js",
    "postinstall": "node scripts/prisma-env.cjs generate --schema database/prisma/schema.prisma && npm run build:backend-ts",
    "build:backend-ts": "tsc -p backend/tsconfig.json",
    "db:generate": "node scripts/prisma-env.cjs generate --schema database/prisma/schema.prisma",
    "db:push": "node scripts/prisma-env.cjs db push --schema database/prisma/schema.prisma",
    "db:migrate": "node scripts/prisma-env.cjs migrate dev --schema database/prisma/schema.prisma",
    "db:migrate:deploy": "node scripts/prisma-env.cjs migrate deploy --schema database/prisma/schema.prisma",
    "db:init": "npm run db:migrate:deploy && npm run db:seed",
    "db:run-sql-scripts": "node backend/db/init-db-script.js",
    "db:migrate:init-structure": "node scripts/prisma-env.cjs migrate dev --name init_structure --schema database/prisma/schema.prisma",
    "db:seed": "node scripts/prisma-env.cjs db seed --schema database/prisma/schema.prisma",
    "client": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "dev": "concurrently -n api,web -c blue,magenta \"cross-env PORT=3001 npm run server:dev\" \"cross-env VITE_API_PORT=3001 npm run client -- --host\""
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "append-field": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.2",
    "typescript": "^5.7.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "zod": "^4.3.6"
  },
  "prisma": {
    "schema": "database/prisma/schema.prisma",
    "seed": "node database/prisma/seed.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.14",
    "prisma": "^5.22.0"
  }
}
